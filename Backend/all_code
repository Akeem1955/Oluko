import asyncio
import json
import logging
import aiohttp
import os
from dotenv import load_dotenv

from livekit.agents import AutoSubscribe, JobContext, WorkerOptions, cli, llm
from livekit.agents.voice_assistant import VoiceAssistant
from livekit.plugins import aws, silero

load_dotenv()
logger = logging.getLogger("neuronflow-agent")

# ==========================================
# 1. DEFINE THE WHITEBOARD TOOLS FOR NOVA
# ==========================================
class WhiteboardTools(llm.FunctionContext):
    def __init__(self, room):
        super().__init__()
        self.room = room # We need the room to send data to the React frontend
        self.backend_url = os.getenv("BACKEND_URL", "http://localhost:8080")

    @llm.ai_callable(description="Use this to draw interactive React/Canvas UI code on the user's whiteboard to explain a concept visually.")
    async def draw_canvas_code(self, prompt_for_nova_lite: str):
        logger.info(f"Nova Sonic used tool: draw_canvas_code with prompt: {prompt_for_nova_lite}")

        # 1. Instantly notify frontend that generation is starting
        processing_payload = json.dumps({"type": "TOOL_PROCESSING", "message": "Generating visual code..."})
        await self.room.local_participant.publish_data(processing_payload.encode('utf-8'))

        # 2. AWAIT natively. Nova Sonic will keep talking/listening in the background.
        async with aiohttp.ClientSession() as session:
            try:
                async with session.post(
                        f"{self.backend_url}/api/v1/internal/tools/generate-canvas",
                        json={"prompt": prompt_for_nova_lite}
                ) as response:
                    if response.status == 200:
                        data = await response.json()
                        generated_code = data.get("code", "")

                        # 3. Broadcast the generated code over LiveKit's Data Channel to Frontend
                        success_payload = json.dumps({
                            "type": "TOOL_CALL_RESULT",
                            "action": "canvas",
                            "payload": generated_code
                        })
                        await self.room.local_participant.publish_data(success_payload.encode('utf-8'))
                        return "Success: The interactive canvas code is now visible on the user's whiteboard."
                    else:
                        logger.error(f"Backend returned {response.status} for canvas generation.")
                        return "Error: Failed to generate the canvas code."
            except Exception as e:
                logger.error(f"Error calling Java backend for canvas: {e}")
                return "Error: Internal server connection failed."

    @llm.ai_callable(description="Use this to generate and display an image on the user's whiteboard.")
    async def insert_image(self, image_description: str):
        logger.info(f"Nova Sonic used tool: insert_image -> {image_description}")

        # 1. Instantly tell React to show a loading state
        processing_payload = json.dumps({"type": "TOOL_PROCESSING", "message": "Generating image..."})
        await self.room.local_participant.publish_data(processing_payload.encode('utf-8'))

        # 2. AWAIT natively. Nova Sonic will keep talking/listening in the background.
        async with aiohttp.ClientSession() as session:
            try:
                async with session.post(
                        f"{self.backend_url}/api/v1/internal/tools/generate-image",
                        json={"prompt": image_description}
                ) as response:
                    if response.status == 200:
                        data = await response.json()
                        image_url = data.get("url", "")

                        # 3. Send final image to React
                        success_payload = json.dumps({
                            "type": "TOOL_CALL_RESULT",
                            "action": "image",
                            "url": image_url
                        })
                        await self.room.local_participant.publish_data(success_payload.encode('utf-8'))

                        # 4. Return the result to Sonic so it knows the visual is on the board
                        return "Success: The image is now visible on the user's whiteboard."
                    else:
                        logger.error(f"Backend returned {response.status} for image generation.")
                        return "Error: Failed to generate the image."
            except Exception as e:
                logger.error(f"Error calling Java backend for image: {e}")
                return "Error: Internal server connection failed."

# ==========================================
# 2. FETCH CONTEXT FROM JAVA BACKEND
# ==========================================
async def fetch_lesson_context(lesson_id: str) -> str:
    """Calls the Java Spring Boot API to get what Nova Sonic should teach."""
    backend_url = os.getenv("BACKEND_URL", "http://localhost:8080")
    try:
        async with aiohttp.ClientSession() as session:
            async with session.get(f"{backend_url}/api/v1/internal/lessons/{lesson_id}/prompt") as response:
                if response.status == 200:
                    data = await response.json()
                    return data.get("systemPrompt", "You are a helpful AI tutor.")
                else:
                    return "You are NeuronFlow, an AI tutor. (Fallback prompt)"
    except Exception as e:
        logger.error(f"Failed to fetch from Java: {e}")
        return "You are NeuronFlow, an AI tutor. (Fallback prompt)"

# ==========================================
# 3. THE LIVEKIT WORKER ENTRYPOINT
# ==========================================
async def entrypoint(ctx: JobContext):
    # Connect to the LiveKit Room
    await ctx.connect(auto_subscribe=AutoSubscribe.AUDIO_ONLY)
    logger.info(f"Agent joined room: {ctx.room.name}")

    # The room name IS the Lesson ID from Java
    lesson_id = ctx.room.name
    system_prompt = await fetch_lesson_context(lesson_id)

    # Initialize Amazon Nova Sonic models via AWS plugin
    nova_llm = aws.LLM(model="amazon.nova-sonic-v1:0")

    # Initialize the Assistant
    assistant = VoiceAssistant(
        vad=silero.VAD.load(), # Voice Activity Detection (Knows when user stops speaking)
        llm=nova_llm,
        fnc_ctx=WhiteboardTools(ctx.room), # Attach our UI tools
        system_prompt=system_prompt,
    )

    # Start the voice session
    assistant.start(ctx.room)

    # AI Greets the user first
    await assistant.say("Hello! I am ready to begin the lesson. Let me know when you are ready.", allow_interruptions=True)

if __name__ == "__main__":
    # Start the LiveKit Worker process
    cli.run_app(WorkerOptions(entrypoint_fnc=entrypoint))



