                    com.cm.neuronflow.internal.domain.UserLearningStats stats = new com.cm.neuronflow.internal.domain.UserLearningStats();
                    stats.setUsers(user);
                    stats.setWeeklyGoalHours(weeklyGoalHours);
                    user.setStats(stats);
                }
            }
