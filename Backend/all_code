import com.cm.neuronflow.internal.domain.Users;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.security.authentication.AuthenticationManager;
import org.springframework.security.authentication.UsernamePasswordAuthenticationToken;
import org.springframework.security.core.Authentication;
import org.springframework.stereotype.Component;

@Component
public class AuthService {
    private final AuthenticationManager authenticationManager;
    private final JwtManager jwtService;

    @Autowired
    public AuthService(AuthenticationManager authenticationManager, JwtManager jwtService) {
        this.jwtService = jwtService;
        this.authenticationManager = authenticationManager;
    }

    public String authenticate(Users authRequest) {
        Authentication authenticationRequest = UsernamePasswordAuthenticationToken.unauthenticated(authRequest.getEmail(), authRequest.getPassword());
        Authentication authenticationResponse = authenticationManager.authenticate(authenticationRequest);
        if(authenticationResponse.isAuthenticated()){
            return jwtService.generateToken(authenticationResponse.getPrincipal().toString());
        }
        throw  new SecurityException();
    }
}



